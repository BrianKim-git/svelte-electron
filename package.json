{
  "name": "svelte-electron",
  "version": "0.1.0",
  "description": "Svelte + Electron + Prisma/SQLite",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "start:renderer": "vite dev --config vite.renderer.config.ts",
    "start:electron": "ELECTRON_RENDERER_URL=http://localhost:5173 electron-vite dev --watch",
    "build": "vite build --config vite.renderer.config.ts && electron-vite build",
    "preview:renderer": "vite build --config vite.renderer.config.ts && vite preview --config vite.renderer.config.ts",
    "preview:electron": "ELECTRON_RENDERER_URL=http://localhost:4173 electron-vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "ui:add": "shadcn-svelte add",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm run typecheck:node && npm run typecheck:renderer",
    "typecheck:node": "tsc --noEmit",
    "typecheck:renderer": "svelte-check --tsconfig src/renderer/tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.0.0",
    "@prisma/client": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "clsx": "^2.1.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "prisma": "^7.8.0",
    "shadcn-svelte": "^1.2.7",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.4.11"
  }
}
